# ─────────────────────────────────────────────
# Lexio — Environment Variables
# Copy this file to .env and adjust values
# ─────────────────────────────────────────────

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lexio
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=lexio

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./var/storage

# App
NODE_ENV=development
PORT=3000

# Auth
AUTH_MODE=LOCAL
AUTH_APP_URL=http://localhost:4200
AUTH_POST_LOGIN_URL=http://localhost:4200/
AUTH_POST_LOGOUT_URL=http://localhost:4200/
AUTH_SESSION_TTL_HOURS=168
AUTH_TRUST_PROXY=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_PASSWORD_RESET_URL=http://localhost:4200/?resetToken={token}&email={email}
AUTH_EMAIL_DELIVERY_MODE=file
AUTH_EMAIL_OUTBOX_PATH=./var/mail-outbox
AUTH_EMAIL_FROM=no-reply@lexio.local
AUTH_EMAIL_REPLY_TO=
AUTH_EMAIL_API_URL=
AUTH_EMAIL_API_KEY=
AUTH_EMAIL_WEBHOOK_URL=
AUTH_EMAIL_WEBHOOK_SECRET=
AUTH_EMAIL_TIMEOUT_MS=8000
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://127.0.0.1:4000,http://localhost:4200,http://127.0.0.1:4200
LEXIO_BOOTSTRAP_PASSWORD=LexioDemo2026!
LEXIO_SEED_PASSWORD=LexioDemo2026!

# OIDC / SSO
OIDC_PROVIDER_LABEL=SSO del despacho
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/sso/callback
OIDC_SCOPE=openid profile email
OIDC_ALLOWED_DOMAINS=
